classDiagram
    direction TB
    
    class Owner {
        +String name
        +int available_time_minutes
        +List~Pet~ pets
        +add_pet(pet: Pet)
        +update_time(minutes: int)
    }

    class Pet {
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +add_task(task: Task)
    }

    class Task {
        +UUID id
        +String category
        +int duration_minutes
        +int priority
        +bool is_completed
        +toggle_completion()
    }

    class SchedulePlanner {
        +Owner current_owner
        +generate_plan() Dictionary
        -sort_tasks(tasks: List) List
    }

    %% Relationships
    Owner "1" *-- "many" Pet : owns
    Pet "1" *-- "many" Task : requires
    SchedulePlanner "1" --> "1" Owner : accesses constraints
    SchedulePlanner ..> Task : filters and sorts